{
  "version": 2,
  "_readme": "Copy to $COLLAB_HOME/seats.json and set only local paths/credentials. The assurance resolver recognizes exactly four logical roles: builder, reviewer, breaker, verifier. Profiles select model overlays for the existing breaker/verifier roles; profiles are not additional seats or dashboard cards.",
  "assessment_profile_revision": "risk-tiered-assurance-v1",
  "models": {
    "gpt-5.6-terra": {
      "provider": "openai",
      "cmd": [
        "python",
        "tools/adapters/openai-repo-seat.py",
        "--base",
        "https://api.openai.com/v1",
        "--model",
        "gpt-5.6-terra",
        "--key-env",
        "OPENAI_API_KEY",
        "--repo-root",
        "."
      ]
    },
    "opus-4.8": {
      "provider": "anthropic",
      "cmd": ["claude", "-p", "--model", "opus-4.8"],
      "unset_env": ["ANTHROPIC_API_KEY"]
    },
    "sonnet-5": {
      "provider": "anthropic",
      "cmd": ["claude", "-p", "--model", "sonnet-5"],
      "unset_env": ["ANTHROPIC_API_KEY"]
    },
    "gpt-5.6-luna": {
      "provider": "openai",
      "cmd": [
        "python",
        "tools/adapters/openai-repo-seat.py",
        "--base",
        "https://api.openai.com/v1",
        "--model",
        "gpt-5.6-luna",
        "--key-env",
        "OPENAI_API_KEY",
        "--repo-root",
        "."
      ]
    },
    "grok-4.5": {
      "provider": "xai",
      "cmd": [
        "python",
        "tools/adapters/openai-repo-seat.py",
        "--base",
        "https://api.x.ai/v1",
        "--model",
        "grok-4.5",
        "--key-env",
        "XAI_API_KEY",
        "--repo-root",
        "."
      ]
    }
  },
  "seats": {
    "builder": {
      "backend": "cli",
      "role": "builder",
      "access": "write",
      "model": "gpt-5.6-terra",
      "tool_policy": {"api": "responses"},
      "system": "You are the BUILDER in a collab-kit handoff loop. Make the requested source changes, preserve paper-trading safety, and report concrete evidence.",
      "timeout": 900
    },
    "reviewer": {
      "backend": "cli",
      "role": "reviewer",
      "access": "read_test",
      "model": "grok-4.5",
      "can_sign_off": true,
      "system": "You are the independent REVIEWER. Inspect the actual repository and allowed test results. Do not edit source; provide evidence-backed blockers or a justified sign-off.",
      "timeout": 900
    },
    "breaker": {
      "backend": "cli",
      "role": "breaker",
      "access": "read_test",
      "model": "opus-4.8",
      "system": "You are the adversarial BREAKER. Inspect the repository and allowed tests, but never edit source. Report only concrete, reproducible findings.",
      "timeout": 900
    },
    "verifier": {
      "backend": "cli",
      "role": "verifier",
      "access": "read_test",
      "model": "sonnet-5",
      "system": "You are the independent VERIFIER. Inspect the repository and allowed tests, but never edit source. Confirm only evidence-backed findings.",
      "timeout": 900
    }
  },
  "assessment_profiles": {
    "baseline": {
      "breaker": {"seat": "breaker"},
      "verifier": {"seat": "verifier"}
    },
    "high-risk-diverse": {
      "extends": "baseline",
      "overrides": {
        "breaker": {"model": "gpt-5.6-luna"},
        "verifier": {"model": "grok-4.5"}
      }
    }
  }
}
