# Collab-kit / autopilot seat secrets (gitignored as collab/.env).
# Copy to collab/.env and fill values. Adapters load this via _load_dotenv().

# --- Preferred: local LiteLLM gateway (litellm-langfuse-gateway) ---
# When LITELLM_VIRTUAL_KEY starts with sk-, openai-compatible-seat and
# openai-repo-seat default --base / --key-env / --model to the gateway and
# attach SERVICE_NAME metadata on every request.
LITELLM_BASE_URL=http://localhost:4000/v1
# From: uv run llg keys create --models llm-general,openai-general,anthropic-general,gemini-general,grok-general \
#   --max-budget 50 --rpm 120 --key-alias ibkr-auto-trader-dev
LITELLM_VIRTUAL_KEY=
SERVICE_NAME=ibkr-auto-trader
# ENVIRONMENT=development
# Optional force alias for seats that don't pass --model:
# LITELLM_MODEL=llm-general

# --- Seat cache telemetry (prompt-caching slice, 2026-07-20) ---
# Both OpenAI-shaped adapters append one JSONL record per LLM POST (ts, adapter, api, model, step,
# prompt_cache_key, prompt_tokens, cached_tokens, cache_write_tokens). Unset -> defaults to
# collab/logs/seat-usage.jsonl (gitignored). Set a path to redirect; set off/0/false/none (or
# empty) to disable. Under pytest the default is OFF unless a test points this at a tmp_path.
# COLLAB_USAGE_LOG=

# --- Direct provider keys (used when gateway virtual key is unset) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# XAI_API_KEY=
# GEMINI_API_KEY=
# SEAT_API_KEY=
# SEAT_API_BASE=https://api.x.ai/v1
# SEAT_API_MODEL=grok-4
