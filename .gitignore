# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# PT-2 SQLite state store: db file + WAL/-shm sidecars (runtime state, not source)
state/*.db
state/*.db-wal
state/*.db-shm

# secrets / local
.env
.env.local
seats.json

# collab-kit RUNTIME state (not source): the autopilot's mutable output — run history, ledgers,
# summaries, leases, assessments, budgets, logs. Git tracks the autopilot *source* under collab/,
# never what it emits. History is disk-backed (run_history "contract A") and dashboard_core reads
# it from disk, so untracking it costs the dashboard nothing.
# If these archives ever need to be durable audit evidence, they get an explicit external
# destination — not an accidental one in the source tree.
autopilot/
# The handoff *specs* (handoffs/**/*.md) and design docs ARE tracked — they're the decision ledger.
logs/
outbox/
handoffs/.idlock/

# one-off backup snapshot
_autopilot-backup-*/

# harness state — untracked per owner request (2026-07-21): kept on local disk, out of the repo.
.claude/
CLAUDE.md

# local scratch architecture notes (not the tracked design docs under docs/)
ARCHITECTURE.md

# one-off codebase-integrity audit snapshots (local design output, not the tracked design ledger)
docs/design/codebase-integrity-audit-*.html
