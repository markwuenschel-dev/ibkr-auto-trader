# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# PT-2 SQLite state store: db file + WAL/-shm sidecars (runtime state, not source)
state/*.db
state/*.db-wal
state/*.db-shm

# secrets / local
.env
.env.local
seats.json

# collab-kit RUNTIME state (not source): autopilot control/replies/status, event logs, outbox.
# The handoff *specs* (handoffs/**/*.md) and design docs ARE tracked — they're the decision ledger.
autopilot/replies/
autopilot/control.json
autopilot/status.json
logs/
outbox/
handoffs/.idlock/

# one-off backup snapshot
_autopilot-backup-*/

# harness state
.claude/*
# ...except the enforcement gates. These are not local preferences — they are the repo's guardrails
# (see CLAUDE.md, "Incident 2026-07-15"). A gate that does not survive a clone is not a gate.
!.claude/settings.json
!.claude/hooks/
.claude/hooks/*
!.claude/hooks/*.py

# local scratch architecture notes (not the tracked design docs under docs/)
ARCHITECTURE.md
